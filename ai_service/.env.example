# AI Service configuration
AI_SERVICE_PORT=8000
BACKEND_URL=http://localhost:3001

# Model provider: auto | bedrock | anthropic | openai
MODEL_PROVIDER=anthropic

# Bedrock path
AWS_REGION=us-east-2
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_STREAMING=false
AI_MAX_TOKENS=5000
AI_TEMPERATURE=0.2

# Direct Anthropic path
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_ID=claude-haiku-4-5-20251001

# Knowledge Base via AgentCore Gateway MCP  
KB_MCP_URL=https://kb-start-hack-gateway-buyjtibfpg.gateway.bedrock-agentcore.us-east-2.amazonaws.com/mcp
KB_MCP_TOOL_NAME=kb-start-hack-target___knowledge_base_retrieve
KB_MCP_MAX_RESULTS=5
# KB_MCP_AUTH_TOKEN=

# Operational MCP endpoint for mission/planner/scenario tools
# The AI agent prefers this MCP path for live mission/planner reads and falls
# back to direct backend HTTP only if the MCP server is unavailable.
OPS_MCP_URL=http://127.0.0.1:9000/mcp
# OPS_MCP_AUTH_TOKEN=
# OPS_MCP_HOST=0.0.0.0
# OPS_MCP_PORT=8000
# OPS_MCP_PATH=/mcp

# Optional fallback provider
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_ID=gpt-4o-mini
