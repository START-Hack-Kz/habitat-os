# AI Service configuration
AI_SERVICE_PORT=8000
BACKEND_URL=http://localhost:3001

# Preferred model provider: direct Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_ID=claude-haiku-4-5-20251001
AI_MAX_TOKENS=1200
AI_TEMPERATURE=0.2

# Knowledge Base via AgentCore Gateway MCP  
KB_MCP_URL=https://kb-start-hack-gateway-buyjtibfpg.gateway.bedrock-agentcore.us-east-2.amazonaws.com/mcp
KB_MCP_TOOL_NAME=kb-start-hack-target___knowledge_base_retrieve
KB_MCP_MAX_RESULTS=5
# KB_MCP_AUTH_TOKEN=

# Optional: operational MCP endpoint for mission/planner/scenario tools
# When set, the AI agent will consume operational tools over MCP instead of
# calling the backend HTTP routes directly.
# OPS_MCP_URL=http://127.0.0.1:9000/mcp
# OPS_MCP_AUTH_TOKEN=
# OPS_MCP_HOST=0.0.0.0
# OPS_MCP_PORT=8000
# OPS_MCP_PATH=/mcp

# Optional fallback provider
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_ID=gpt-4o-mini
